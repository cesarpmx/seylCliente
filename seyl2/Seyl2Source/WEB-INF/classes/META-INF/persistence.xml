<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" 
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
             
  <persistence-unit name="Argo" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    
    <exclude-unlisted-classes>false</exclude-unlisted-classes>
    
    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="oracle.jdbc.driver.OracleDriver"/>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:oracle:thin:@transfermx.dyndns.org:1521:xe"/>
      <property name="jakarta.persistence.jdbc.user" value="seyl2"/>
      <property name="jakarta.persistence.jdbc.password" value="seyl2"/>
      
      <property name="eclipselink.target-database" value="Oracle"/>
      
      <property name="eclipselink.weaving" value="false"/>
    </properties>
  </persistence-unit>
</persistence>